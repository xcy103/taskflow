# server/.env — copy to server/.env for running the API standalone (outside compose).
# 5001 (not 5000) — macOS AirPlay/Control Center occupies 5000.
PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://taskflow:changeme@localhost:27017/taskflow?authSource=admin
JWT_ACCESS_SECRET=replace-with-random-secret
JWT_REFRESH_SECRET=replace-with-another-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CLIENT_ORIGIN=http://localhost:5173
