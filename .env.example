# Root env template (used by docker-compose). Copy to .env and fill in.
# NEVER commit the real .env.

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=taskflow
MONGO_INITDB_ROOT_PASSWORD=changeme
# API connects to the mongo service by name inside docker-compose:
MONGODB_URI=mongodb://taskflow:changeme@mongo:27017/taskflow?authSource=admin

# --- API ---
# 5001 (not 5000) — on macOS port 5000 is taken by the AirPlay/Control Center receiver.
PORT=5001
NODE_ENV=development
# Generate strong secrets, e.g.:  openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-random-secret
JWT_REFRESH_SECRET=replace-with-another-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CLIENT_ORIGIN=http://localhost:5173

# --- Client ---
VITE_API_URL=http://localhost:5001/api
